{
  "name": "offshore-wind-masters-web",
  "private": true,
  "version": "3.32.0-web-audio-engine",
  "type": "module",
  "scripts": {
    "sync:data": "node tools/sync-data.mjs",
    "sync:art": "node tools/sync-art.mjs",
    "scene:generate": "python tools/generate-scene-feed-variants.py",
    "art:manifest": "node tools/build-p01-manifest.mjs",
    "art:qa-overrides": "node tools/apply-art-qa-overrides.mjs",
    "art:visual-overrides": "node tools/apply-visual-qa-overrides.mjs",
    "art:import-correction": "node tools/import-art-correction.mjs",
    "art:r6-sanitize": "node tools/sanitize-r6-feminine-profile-contradictions.mjs",
    "art:r6-pack": "node tools/export-r6-batch-generation-pack.mjs",
    "art:r7-upgrade": "node tools/upgrade-p01-r6-workforce-diversity.mjs",
    "art:r7-pack": "node tools/export-r6-batch-generation-pack.mjs",
    "dev": "pnpm sync:data && pnpm sync:art && vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "simulate:balance": "node --no-warnings --experimental-strip-types tools/simulate-campaign-balance.ts",
    "simulate:challenge": "node --no-warnings --experimental-strip-types tools/simulate-boss-challenge-balance.ts",
    "smoke:gameplay": "node tools/smoke-gameplay.mjs",
    "smoke:challenge": "node tools/smoke-challenge.mjs",
    "smoke:layout": "node tools/smoke-layout.mjs",
    "smoke:deployment:compact": "node tools/smoke-deployment-compact.mjs",
    "smoke:operation:compact": "node tools/smoke-operation-compact.mjs",
    "smoke:sandbox": "node tools/smoke-sandbox-scenario.mjs",
    "smoke:scene": "node tools/smoke-scene-routing.mjs",
    "smoke:fleet": "node tools/smoke-fleet-maintenance.mjs",
    "smoke:onboarding": "node tools/smoke-onboarding.mjs",
    "smoke:art": "node tools/smoke-source-art.mjs",
    "build": "pnpm sync:data && pnpm sync:art && tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "validate:data": "python tools/validate_owm_data.py",
    "validate:art": "node tools/validate-art-prompts.mjs",
    "validate": "pnpm simulate:challenge && pnpm sync:data && pnpm validate:data && pnpm validate:art && pnpm test && pnpm simulate:balance && pnpm build"
  },
  "dependencies": {
    "phaser": "4.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "playwright-core": "1.61.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.7.0"
}
